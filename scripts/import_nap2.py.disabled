#!/usr/bin/env python3
"""import_nap2.py — 匯入第二期國家人權行動計畫(2025-2027)兒少相關行動。

Wave 86:對應 _public/nap.html 之第二期 placeholder。
等行政院 / NHRC 公布完整 NAP 第二期後執行。

預期內容(根據 NHRC 2025-07 §12 已知建議):
  - NHRC 兒少權利專責單位設立(CRC2-CO12)
  - 反歧視法 / 難民法立法時程
  - 兒少預算公開儀表板(CRC2-CO13)
  - 兒少生活狀況調查改採單獨線上問卷
  - 第一期延續項目(自殺研究公布、生活狀況改版、反歧視法)

用法:
    python3 scripts/import_nap2.py --csv data/sources/NAP2_actions.csv  # 從 CSV
    python3 scripts/import_nap2.py --json data/sources/NAP2_actions.json  # 從 JSON
    python3 scripts/import_nap2.py --predicted   # 灌入「依 NHRC 預期」之 placeholder

CSV 格式範例:
    action_id,theme_no,theme_name,sub_section,action_text,kpi,target_year,lead_agency
    NAP2-01-專責單位,1,強化人權保障體制,NHRC 兒少權利專責單位,設立兒少權利專責單位,完成設立 + 員額,2027,NHRC
"""
from __future__ import annotations

import argparse
import csv
import json
import sqlite3
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
DB = ROOT / "data" / "crw.db"


