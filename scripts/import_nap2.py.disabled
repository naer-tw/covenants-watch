        "co_agencies": '["外交部"]', "related_pi": '["PI-13"]', "related_co": '["CRC2-CO25","CRC2-CO61"]',
        "govt_status": "--", "nhrc_severity": "--", "aabe_assessment": "--",
        "aabe_evidence": "草案 2005 送立法院 21 年未通過,第二期應確定立法時程",
