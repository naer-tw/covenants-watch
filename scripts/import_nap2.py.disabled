        "govt_status": "--", "nhrc_severity": "--", "aabe_assessment": "--",
        "aabe_evidence": "8,743 份青少年問卷期待透明化",
    },
]


def import_records(records: list[dict]) -> int:
    if not records:
        return 0
    conn = sqlite3.connect(str(DB))
    n = 0
    for r in records:
        conn.execute("""
            INSERT OR REPLACE INTO nap_action(action_id, nap_period, theme_no, theme_name,
                sub_section, action_text, kpi, target_year, lead_agency, co_agencies,
                govt_self_assessment, govt_status, nhrc_comment, nhrc_severity,
                aabe_assessment, aabe_evidence, related_pi, related_co,
                recommend_carry_forward, last_updated)
            VALUES (?,'2',?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,date('now'))
        """, (
            r["action_id"], r["theme_no"], r["theme_name"], r.get("sub_section"),
            r["action_text"], r.get("kpi"), r.get("target_year"),
            r.get("lead_agency"), r.get("co_agencies", "[]"),
            r.get("govt_self_assessment", "--"), r.get("govt_status", "--"),
            r.get("nhrc_comment", "--"), r.get("nhrc_severity", "--"),
            r.get("aabe_assessment", "--"), r.get("aabe_evidence", ""),
            r.get("related_pi", "[]"), r.get("related_co", "[]"),
            r.get("recommend_carry_forward", 0),
        ))
        n += 1
    conn.commit()
    # 移除 placeholder
    conn.execute("DELETE FROM nap_action WHERE action_id='NAP2-PLACEHOLDER'")
    conn.commit()
    conn.close()
    return n


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--csv", help="從 CSV 讀")
    ap.add_argument("--json", help="從 JSON 讀")
    ap.add_argument("--predicted", action="store_true",
                    help="使用 6 項依 NHRC §12 預期之 placeholder(等行政院公布後須校正)")
    args = ap.parse_args()

    if args.predicted:
        records = PREDICTED_NAP2
        print(f"使用預期 placeholder({len(records)} 項;等行政院公布後須校正)")
    elif args.csv:
        with open(args.csv, encoding="utf-8") as f:
            records = list(csv.DictReader(f))
    elif args.json:
        records = json.loads(Path(args.json).read_text(encoding="utf-8"))
    else:
        ap.print_help()
        return 0

    n = import_records(records)
    print(f"✓ 寫入 nap_action 第二期 {n} 筆")
    print("提示:重跑 python3 scripts/render_nap.py --update 更新 _public/nap.html")
    return 0


if __name__ == "__main__":
    sys.exit(main())
